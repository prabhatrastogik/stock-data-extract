# Kite Connect API credentials
# Get these from https://developers.kite.trade/
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Kite account credentials (used for automated token refresh)
KITE_USER_ID=your_zerodha_user_id
KITE_PASSWORD=your_zerodha_password
KITE_TOTP_SECRET=your_totp_base32_secret  # from the 2FA authenticator setup page

# Access token — optional if KITE_USER_ID/PASSWORD/TOTP_SECRET are set,
# since the app will auto-refresh via browser login when the token expires.
# Required only if running without auto-refresh credentials.
# KITE_ACCESS_TOKEN=your_access_token_here

# Cloudflare R2 credentials
# Get these from the Cloudflare dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=stock-data  # single source of truth — also read directly by Litestream

# Optional: override config file path (default: config.yaml in cwd)
# CONFIG_PATH=/path/to/config.yaml

# SQLite database path — single source of truth shared by the binary, litestream.yml, and start.sh.
# Set to wherever your persistent volume/disk is mounted (e.g. /mnt/data/stock.db on EC2/EBS,
# /data/stock.db with Docker). Defaults to ./data/stock.db if unset.
SQLITE_PATH=/data/stock.db

# Litestream backup path within the R2 bucket.
# Prefix with an env name if multiple deployments share the same bucket (e.g. prod/sqlite-backup/stock.db).
LITESTREAM_BACKUP_PATH=sqlite-backup/stock.db
